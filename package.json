{
  "name": "cannery",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:frontend": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
